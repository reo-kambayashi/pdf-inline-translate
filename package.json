{
  "name": "pdf-inline-translate",
  "version": "0.1.0",
  "description": "Obsidian の PDF ビューア内翻訳プラグイン",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "node esbuild.config.mjs",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"{src,tests}/**/*.{ts,js,json}\"",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "translation",
    "pdf",
    "gemini"
  ],
  "author": "Reo",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "@vitest/coverage-v8": "^2.1.3",
    "esbuild": "^0.23.0",
    "eslint": "^9.11.0",
    "msw": "^2.4.1",
    "obsidian": "^1.6.3",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vitest": "^2.1.3"
  },
  "dependencies": {
    "tslib": "^2.6.3"
  }
}
