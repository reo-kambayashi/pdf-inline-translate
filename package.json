{
  "name": "pdf-inline-translate",
  "version": "1.1.0",
  "description": "PDF++ プラグインで表示した PDF 内の選択テキストを Google Gemini に送信し、即座に翻訳結果を表示・コピーできる Obsidian プラグインです。",
  "main": "main.js",
  "scripts": {
    "test": "vitest",
    "dev": "node esbuild.config.js",
    "build": "BUILD=production node esbuild.config.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reo-kambayashi/pdf-inline-translate.git"
  },
  "keywords": [
    "obsidian",
    "pdf",
    "translation",
    "gemini",
    "ai"
  ],
  "author": "reo",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/reo-kambayashi/pdf-inline-translate/issues"
  },
  "homepage": "https://github.com/reo-kambayashi/pdf-inline-translate#readme",
  "dependencies": {
    "tslib": "^2.8.0"
  },
  "devDependencies": {
    "@types/node": "^24.7.0",
    "esbuild": "^0.25.10",
    "eslint": "^9.37.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "obsidian": "^1.10.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vitest": "^3.2.4"
  }
}
